{
  "name": "@finografic/project-scripts",
  "type": "module",
  "version": "1.1.1",
  "engines": {
    "node": ">=24.3.0"
  },
  "description": "Fingorafic Project Scripts",
  "homepage": "https://github.com/finografic/project-scripts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finografic/project-scripts.git"
  },
  "bugs": {
    "url": "https://github.com/finografic/project-scripts/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "author": {
    "name": "Justin",
    "email": "justin.blair.rankin@gmail.com",
    "url": "http://finografic.github.com/cv-justin-rankin"
  },
  "license": "MIT",
  "keywords": [
    "project-scripts",
    "build-tools",
    "deployment",
    "cross-platform",
    "monorepo",
    "clean",
    "purge",
    "database-setup",
    "sqlite",
    "sqlite3",
    "better-sqlite3",
    "typescript",
    "cli",
    "finografic"
  ],
  "main": "./dist/utils.mjs",
  "types": "./dist/utils.d.mts",
  "module": "./dist/utils.mjs",
  "files": [
    "bin",
    "dist",
    "src/build-deployment/templates"
  ],
  "bin": {
    "clean-docs": "bin/clean-docs.mjs",
    "db-setup": "bin/db-setup.mjs",
    "purge-builds": "bin/purge-builds.mjs",
    "sqlite-rebuild": "bin/sqlite-rebuild.mjs",
    "build-deployment": "bin/build-deployment.mjs",
    "github-release": "./bin/github-release.mjs",
    "audit-script-separators": "./bin/audit-script-separators.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/utils.d.mts",
      "import": "./dist/utils.mjs"
    },
    "./clean-docs": {
      "types": "./dist/clean-docs.d.mts",
      "import": "./dist/clean-docs.mjs"
    },
    "./db-setup": {
      "types": "./dist/db-setup.d.mts",
      "import": "./dist/db-setup.mjs"
    },
    "./db-setup/config.template": {
      "types": "./dist/db-setup/config.template.d.mts",
      "import": "./dist/db-setup/config.template.mjs"
    },
    "./purge-builds": {
      "types": "./dist/purge-builds.d.mts",
      "import": "./dist/purge-builds.mjs"
    },
    "./sqlite-rebuild": {
      "types": "./dist/sqlite-rebuild.d.mts",
      "import": "./dist/sqlite-rebuild.mjs"
    },
    "./build-deployment": {
      "types": "./dist/build-deployment.d.mts",
      "import": "./dist/build-deployment.mjs"
    },
    "./audit-script-separators": {
      "types": "./dist/audit-script-separators.d.mts",
      "import": "./dist/audit-script-separators.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "---------- DEV_AND_BUILD": "---------------------------------------------",
    "dev": "npx @eslint/config-inspector --config eslint.config.ts",
    "link": "pnpm build && pnpm link --global",
    "unlink": "pnpm unlink --global",
    "build": "tsdown",
    "·········· TESTING": "···················································",
    "test": "vitest",
    "test.run": "vitest run",
    "test.run.silent": "vitest run --silent",
    "test.coverage": "vitest run --coverage",
    "·········· LINTING": "···················································",
    "lint": "eslint .",
    "lint.fix": "eslint . --fix",
    "·········· FORMATTING": "················································",
    "format.check": "oxfmt --check",
    "format.fix": "oxfmt",
    "·········· PUBLISH.GITHUB": "············································",
    "release.github.patch": "pnpm run release.check && pnpm version patch && git push --follow-tags",
    "release.github.minor": "pnpm run release.check && pnpm version minor && git push --follow-tags",
    "release.github.major": "pnpm run release.check && pnpm version major && git push --follow-tags",
    "release.check": "pnpm format.check && pnpm lint.fix && pnpm typecheck && pnpm test.run.silent",
    "release.publish": "pnpm publish --registry https://npm.pkg.github.com",
    "·········· REGISTRIES": "··············································",
    "view.registry.github": "pnpm view @finografic/project-scripts --registry=https://npm.pkg.github.com",
    "·········· PACKAGES": "···················································",
    "update.core": "pnpm update @finografic/core --latest",
    "update.eslint-config": "pnpm update @finografic/eslint-config --latest",
    "update.oxfmt-config": "pnpm update @finografic/oxfmt-config --latest && pnpm update oxfmt --latest",
    "upgrade.deps.all": "pnpm update --latest",
    "·········· UTILS": "·····················································",
    "tsc.debug": "tsc --pretty --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "tooling.check": "tsx scripts/check-tooling.ts",
    "prepack": "pnpm build",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@inquirer/confirm": "5.1.18",
    "@inquirer/core": "10.2.2",
    "@inquirer/input": "4.2.4",
    "@inquirer/prompts": "7.8.6",
    "del": "8.0.1",
    "execa": "9.6.1",
    "ora": "9.0.0",
    "parse-gitignore": "^2.0.0",
    "picocolors": "^1.1.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@dotenvx/dotenvx": "1.51.0",
    "@eslint/js": "^9.39.2",
    "@finografic/eslint-config": "9.18.4",
    "@finografic/oxfmt-config": "^1.0.3",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@types/node": "^24.0.0",
    "@types/yargs": "^17.0.33",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "^9.39.2",
    "eslint-plugin-markdownlint": "^0.9.0",
    "globals": "^17.3.0",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.43.0",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "0.20.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "tsx": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "tsx": {
      "optional": false
    }
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "dprint",
      "esbuild",
      "simple-git-hooks",
      "unrs-resolver"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "eslint --fix"
    ],
    "*.md": [
      "eslint --fix"
    ],
    "*.{json,jsonc,md,yml,yaml,toml}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  }
}
